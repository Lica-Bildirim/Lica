<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title> LICA-Bildirim Işığı ve Fener — Privacy Policy</title>
<meta name="description" content="LICA-Bildirim Işığı ve Fener app privacy policy. How your information is collected, used, and protected.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:ital,wght@0,300;0,400;0,600;0,700;1,300&display=swap" rel="stylesheet">
<style>
:root{
  --c:#00E5FF;
  --c2:rgba(0,229,255,0.5);
  --c3:rgba(0,229,255,0.08);
  --bg:#04070E;
  --bg2:#080D18;
  --bg3:#0C1220;
  --bd:#162030;
  --bd2:#1E2D40;
  --tx:#B0C4D4;
  --mt:#344556;
  --gr:#00E5A0;
  --or:#FF9500;
  --rd:#FF3D55;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  background:var(--bg);
  color:var(--tx);
  font-family:'Exo 2',sans-serif;
  overflow-x:hidden;
  line-height:1.6;
}

/* noise texture */
body::before{
  content:'';
  position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events:none;z-index:0;opacity:0.4;
}

/* ambient */
body::after{
  content:'';
  position:fixed;inset:0;
  background:
    radial-gradient(ellipse 70% 50% at 5% 0%,rgba(0,229,255,0.07) 0%,transparent 55%),
    radial-gradient(ellipse 50% 70% at 95% 100%,rgba(0,150,180,0.05) 0%,transparent 55%);
  pointer-events:none;z-index:0;
}

.z{position:relative;z-index:1;}
.wrap{max-width:1000px;margin:0 auto;padding:0 24px;}

/* ═══════════════ NAV ═══════════════ */
nav{
  position:sticky;top:0;z-index:200;
  background:rgba(4,7,14,0.88);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--bd);
}
.nav-in{
  display:flex;align-items:center;
  justify-content:space-between;
  padding:14px 0;
}
.logo{
  font-family:'Orbitron',monospace;
  font-weight:900;font-size:18px;
  color:var(--c);letter-spacing:3px;
  text-decoration:none;
  text-shadow:0 0 20px var(--c2);
}
.logo em{color:rgba(0,229,255,0.35);font-style:normal;}
.nav-right{display:flex;align-items:center;gap:8px;}
.lang-btn{
  padding:6px 14px;
  background:var(--c3);
  border:1px solid rgba(0,229,255,0.2);
  border-radius:20px;
  color:var(--c);
  font-family:'Exo 2',sans-serif;
  font-size:12px;font-weight:600;
  letter-spacing:1px;cursor:pointer;
  transition:all .2s;
}
.lang-btn:hover{background:rgba(0,229,255,0.15);}
.nav-cta{
  padding:8px 20px;
  background:var(--c);
  color:#04070E;
  font-family:'Orbitron',monospace;
  font-size:10px;font-weight:700;
  letter-spacing:2px;
  border:none;border-radius:4px;
  cursor:pointer;text-decoration:none;
  transition:all .2s;
  box-shadow:0 0 20px rgba(0,229,255,0.2);
}
.nav-cta:hover{background:#fff;box-shadow:0 0 30px rgba(0,229,255,0.5);}

/* ═══════════════ PRIVACY CONTENT ═══════════════ */
.privacy-section{
  padding:60px 0 80px;
  min-height:calc(100vh - 200px);
}

.privacy-header{
  text-align:center;
  margin-bottom:50px;
}

.privacy-header h1{
  font-family:'Orbitron',monospace;
  font-size:clamp(24px,4vw,42px);
  font-weight:900;
  color:#fff;
  margin-bottom:15px;
  text-transform:uppercase;
  letter-spacing:2px;
}

.privacy-header h1 span{
  color:var(--c);
  text-shadow:0 0 20px var(--c2);
}

.privacy-header .last-updated{
  color:var(--mt);
  font-size:14px;
  margin-bottom:5px;
}

.privacy-header .developer{
  color:var(--c);
  font-size:16px;
  font-weight:600;
}

.privacy-header .contact{
  color:var(--mt);
  font-size:14px;
  margin-top:10px;
}

.privacy-header .contact a{
  color:var(--c);
  text-decoration:none;
  border-bottom:1px dashed var(--c2);
}

.privacy-header .contact a:hover{
  color:var(--c);
  border-bottom:1px solid var(--c);
}

.privacy-card{
  background:var(--bg2);
  border:1px solid var(--bd2);
  border-radius:24px;
  padding:40px;
  box-shadow:0 20px 40px rgba(0,0,0,0.5);
  position:relative;
  overflow:hidden;
}

.privacy-card::before{
  content:'';
  position:absolute;
  top:0;
  left:0;
  right:0;
  height:2px;
  background:linear-gradient(90deg, transparent, var(--c), transparent);
}

.privacy-card::after{
  content:'';
  position:absolute;
  bottom:0;
  left:0;
  right:0;
  height:1px;
  background:linear-gradient(90deg, transparent, var(--bd2), transparent);
}

.policy-section{
  margin-bottom:30px;
  padding-bottom:20px;
  border-bottom:1px solid var(--bd);
}

.policy-section:last-child{
  border-bottom:none;
  margin-bottom:0;
  padding-bottom:0;
}

.policy-section h2{
  font-family:'Orbitron',monospace;
  font-size:18px;
  color:var(--c);
  margin-bottom:15px;
  letter-spacing:1px;
  display:flex;
  align-items:center;
  gap:8px;
}

.policy-section h2 .section-number{
  color:var(--mt);
  font-size:14px;
  font-family:'Exo 2',sans-serif;
}

.policy-section p{
  color:var(--tx);
  font-size:15px;
  margin-bottom:15px;
}

.policy-section ul, .policy-section ol{
  margin:15px 0 15px 25px;
  color:var(--tx);
  font-size:15px;
}

.policy-section li{
  margin-bottom:8px;
}

.policy-section li strong{
  color:var(--c);
  font-weight:600;
}

.policy-section .permission-group{
  background:var(--bg3);
  border:1px solid var(--bd);
  border-radius:12px;
  padding:15px;
  margin:15px 0;
}

.policy-section .permission-item{
  display:flex;
  align-items:flex-start;
  gap:10px;
  padding:8px 0;
  border-bottom:1px solid var(--bd);
}

.policy-section .permission-item:last-child{
  border-bottom:none;
}

.policy-section .permission-name{
  font-family:'Orbitron',monospace;
  color:var(--c);
  font-size:13px;
  min-width:140px;
}

.policy-section .permission-desc{
  color:var(--tx);
  font-size:13px;
  line-height:1.5;
}

.policy-section .highlight{
  color:var(--gr);
  font-weight:600;
}

.policy-section .note{
  background:rgba(0,229,255,0.05);
  border-left:3px solid var(--c);
  padding:12px 15px;
  border-radius:0 8px 8px 0;
  margin:15px 0;
  font-style:italic;
  color:var(--mt);
}

.policy-footer{
  margin-top:40px;
  text-align:center;
  color:var(--mt);
  font-size:14px;
  border-top:1px solid var(--bd);
  padding-top:30px;
}

.policy-footer a{
  color:var(--c);
  text-decoration:none;
  margin:0 10px;
  transition:all .2s;
}

.policy-footer a:hover{
  text-shadow:0 0 8px var(--c2);
}

.separator{
  color:var(--bd2);
  margin:0 5px;
}

/* ═══════════════ FOOTER ═══════════════ */
footer{
  border-top:1px solid var(--bd);
  padding:32px 0;
  text-align:center;
}
footer p{
  color:var(--mt);
  font-size:12px;
  letter-spacing:.5px;
}
footer a{
  color:var(--c);
  text-decoration:none;
}
footer a:hover{
  text-decoration:underline;
}

/* ═══════════════ RESPONSIVE ═══════════════ */
@media(max-width:600px){
  .privacy-card{padding:25px;}
  .policy-section .permission-item{flex-direction:column;gap:5px;}
  .policy-section .permission-name{min-width:auto;}
  .privacy-header h1{font-size:28px;}
}

@media(max-width:400px){
  .wrap{padding:0 16px;}
  .privacy-card{padding:20px;}
  .policy-section h2{font-size:16px;}
}
</style>
</head>
<body>

